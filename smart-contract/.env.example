# Wallet deployer (0x prefix, 64 hex chars)
PRIVATE_KEY=REPLACE_WITH_YOUR_PRIVATE_KEY

# Optional owner override. If empty, owner = address dari PRIVATE_KEY
OWNER_ADDRESS=

# Base Mainnet RPC
BASE_RPC_URL=https://mainnet.base.org

# Dipakai oleh script deploy saat ini
RPC_URL=https://mainnet.base.org
